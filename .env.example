# ShadowTransfer — per-environment settings (single source of truth).
#
# Copy this file to `.env`, fill in the four values for your environment,
# then `source .env` before running any script (python or SLURM submit).
# Every path, account, and partition in the repo resolves from these vars.
#
#   cp .env.example .env
#   # edit .env
#   source .env

# Absolute path to the project root. The scripts expect data and outputs under
# $PROJECT_ROOT/data/... and the code/checkpoints under $PROJECT_ROOT/python/...
# Required by every .py and .sh script (submit wrappers fail loudly if unset).
export PROJECT_ROOT="/abs/path/to/shadowtransfer"

# SLURM account charged for jobs (sbatch -A / --account).
export SLURM_ACCOUNT="your_account"

# SLURM partition / queue to submit to (sbatch -p / --partition).
export SLURM_PARTITION="your_partition"

# Node(s) to exclude from scheduling (sbatch --exclude). Leave blank if none.
export NODE=""
